type fingerprint_data_file, data_file_type, file_type;
type vendor_sysfs_udfps, sysfs_type, fs_type;
type vendor_hal_fingerprint_hwservice_xiaomi, hwservice_manager_type;
type vendor_hal_fingerprint_service_xiaomi, service_manager_type;
type vendor_touchfeature_device, dev_type;
type vendor_fingerprint_device, dev_type;
vendor_internal_prop(vendor_fp_prop)

vndbinder_use(hal_fingerprint_default)

allow hal_fingerprint_default fingerprint_data_file:dir create_dir_perms;
allow hal_fingerprint_default fingerprint_data_file:file create_file_perms;
allow hal_fingerprint_default input_device:dir r_dir_perms;
allow hal_fingerprint_default self:netlink_kobject_uevent_socket { bind create read setopt };
allow hal_fingerprint_default input_device:chr_file rw_file_perms;
allow hal_fingerprint_default self:netlink_socket create_socket_perms_no_ioctl;
allow hal_fingerprint_default sysfs_gpu:dir r_dir_perms;
allow hal_fingerprint_default sysfs_gpu:file rw_file_perms;
allow hal_fingerprint_default vendor_sysfs_udfps:file rw_file_perms;
allow hal_fingerprint_default vendor_touchfeature_device:chr_file rw_file_perms;
allow hal_fingerprint_default self:capability { sys_nice };
allow hal_fingerprint_default vendor_fingerprint_device:chr_file rw_file_perms;
allow hal_fingerprint_default mitee_client_device:chr_file rw_file_perms;
allow hal_fingerprint_default vendor_displayfeature_device:chr_file rw_file_perms;

rw_dir_file(hal_fingerprint_default, sysfs_therm)

set_prop(hal_fingerprint_default, vendor_fp_prop)

add_hwservice(hal_fingerprint_default, vendor_hal_fingerprint_hwservice_xiaomi)
add_service(hal_fingerprint_default, vendor_hal_fingerprint_service_xiaomi)
