type vendor_displayfeature_device, dev_type;

binder_call(hal_graphics_composer_default, vendor_hal_citsensorservice_xiaomi_default)

allow hal_graphics_composer_default sysfs_gpu:file rw_file_perms;
allow hal_graphics_composer_default sysfs_leds:file rw_file_perms;
allow hal_graphics_composer_default proc_ged:chr_file { ioctl open read };

hal_server_domain(hal_graphics_composer_default, vendor_hal_citsensorservice_xiaomi)

r_dir_file(hal_graphics_composer_default, sysfs_leds)
rw_dir_file(hal_graphics_composer_default, sysfs_ged)
